{
  "name": "identican",
  "version": "0.3.2",
  "description": "Deterministic Soda-Can SVG Identicons",
  "keywords": [
    "identicon",
    "avatar",
    "svg",
    "deterministic",
    "generative"
  ],
  "author": "Jakub Vonášek",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jvonasek/identican.git"
  },
  "homepage": "https://jvonasek.github.io/identican",
  "bugs": "https://github.com/jvonasek/identican/issues",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc --emitDeclarationOnly && esbuild src/index.ts --bundle --format=esm --minify --outfile=dist/index.js",
    "test": "npm run build && node --test",
    "demo": "node scripts/demo.mjs",
    "benchmark": "npm run build && node benchmark/node.js",
    "benchmark:page": "node scripts/benchmark-page.mjs",
    "dev": "node --watch-path=./src --watch-path=./scripts/templates --watch-path=./scripts/themes scripts/demo.mjs",
    "format": "prettier --write .",
    "prepublishOnly": "npm test"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "26.0.1",
    "esbuild": "0.28.1",
    "eta": "4.6.0",
    "prettier": "3.9.1",
    "typescript": "^5.5.0"
  }
}
